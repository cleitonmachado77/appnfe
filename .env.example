# ============================================================
# NF-e Delivery Proof — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- API ---
PORT=3001
NODE_ENV=development

# --- Database (local Docker) ---
DATABASE_URL=postgresql://nfe_user:nfe_password@localhost:5432/nfe_delivery
POSTGRES_USER=nfe_user
POSTGRES_PASSWORD=nfe_password
POSTGRES_DB=nfe_delivery

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h

# --- Supabase (production / staging) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key
SUPABASE_STORAGE_BUCKET=nfe-images

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- MeuDanfe API ---
MEUDANFE_API_KEY=2c0cc96a-1b1c-4548-87c9-58810c302030

# --- Certificado Digital A1 (DF-e SEFAZ) ---
# Chave de criptografia para os certificados armazenados no banco (AES-256-GCM)
# Gere com: openssl rand -base64 32
CERT_ENCRYPTION_KEY=change-me-use-openssl-rand-base64-32

# Ambiente SEFAZ: 1=produção, 2=homologação (controlado por NODE_ENV)
# Em NODE_ENV=production usa ambiente 1, caso contrário usa 2
